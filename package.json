{
  "name": "dataflow",
  "version": "0.1.0",
  "description": "Secure, self-hosted family data vault — web application",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js | npx pino-pretty",
    "test": "c8 node --test --test-force-exit tests/*.test.js",
    "test:fast": "node --test --test-force-exit tests/*.test.js",
    "test:security": "node --test --test-force-exit tests/security.test.js tests/csrf.test.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "seed": "node src/db/seed.js",
    "validate": "npm run lint && npm run test:fast"
  },
  "keywords": [
    "data-vault",
    "password-manager",
    "family",
    "self-hosted",
    "encrypted",
    "sqlite",
    "express"
  ],
  "author": "Learn by Exploration",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "argon2": "^0.43.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.2",
    "pino": "^10.3.1",
    "pino-http": "^10.5.0",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "c8": "^10.1.3",
    "eslint": "^9.28.0",
    "globals": "^16.1.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
