# DataFlow Environment Configuration
# Copy this file to .env and adjust values as needed.
# All values shown are defaults — the app works without a .env file.

# Server
PORT=3460
NODE_ENV=development

# Database directory (where dataflow.db lives)
DB_DIR=./data

# Logging
LOG_LEVEL=info          # silent | error | warn | info | debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Bcrypt (login password hashing)
BCRYPT_SALT_ROUNDS=12

# Argon2id (vault key derivation)
ARGON2_MEMORY=65536       # Memory cost in KiB (64 MiB)
ARGON2_TIME=3             # Iterations
ARGON2_PARALLELISM=1      # Parallelism

# Session
SESSION_MAX_AGE_DAYS=7

# Vault Auto-Lock
AUTO_LOCK_MINUTES=5       # Minutes of inactivity before vault locks

# Max Attachment Size
MAX_ATTACHMENT_SIZE=10485760  # 10 MB in bytes

# Backup
BACKUP_RETAIN_COUNT=7
BACKUP_INTERVAL_HOURS=24

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Reverse Proxy
# Set to "true" when behind Nginx, Caddy, etc.
# TRUST_PROXY=true

# CORS
# Comma-separated list of allowed origins.
# Leave empty for same-origin only (default).
# ALLOWED_ORIGINS=https://app.example.com
